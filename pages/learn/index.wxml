<view class="learn-page">
  <view class="pet-board">
    <view class="pet-left">
      <text class="pet-icon">🏆</text>
      <view class="pet-info">
        <text class="pet-level">Lv.{{growth.level}}</text>
        <view class="progress-track">
          <view class="progress-fill" style="width: {{levelProgressPercent}}%;"></view>
        </view>
        <text class="progress-text">{{levelProgress}} / 100 EXP</text>
      </view>
    </view>
    <text wx:if="{{expToastVisible}}" class="exp-toast">{{expToastText}}</text>
  </view>

  <view wx:if="{{isExpandedWords}}" class="expand-tip">本学期已学完，当前为扩展词汇</view>

  <view wx:if="{{!hasDictionaryData}}" class="empty-panel">
    <text class="empty-emoji">🚧</text>
    <text class="empty-title">当前词库暂未开放</text>
    <text class="empty-text">当前年级/学期的词库正在由老师紧急录入中，请先去【我的】页面切换到【6年级 下学期】体验吧！</text>
    <button class="empty-button" bindtap="onGoProfile">去我的页面切换</button>
  </view>

  <view wx:elif="{{isResting}}" class="rest-panel">
    <text class="rest-emoji">🎯</text>
    <text class="rest-title">太棒啦！</text>
    <text class="rest-text">你已经连续学了 {{restTriggerCount}} 个单词，让大脑休息一下吧！</text>
    <button class="rest-button" bindtap="onGoGame">🎮 去玩个小游戏</button>
    <text class="rest-link" bindtap="onContinueLearning">我不累，继续背</text>
  </view>

  <block wx:elif="{{currentIndex < words.length}}">
    <view class="progress-text">
      {{currentIndex + 1}} / {{words.length}}
    </view>

    <view class="word-card">
      <text class="word">{{words[currentIndex].word}}</text>
      <text class="phonetic">{{words[currentIndex].phonetic}}</text>

      <view wx:if="{{words[currentIndex].image_url}}" class="image-wrap">
        <image class="word-image" src="{{words[currentIndex].image_url}}" mode="aspectFill"></image>
      </view>

      <view wx:else class="image-placeholder">
        <text class="image-placeholder__text">🖼️ 图片准备中</text>
      </view>

      <view class="sound-button" bindtap="onPlaySound">
        <text class="sound-button__text">▶ 播放声音</text>
      </view>

      <view class="meaning-area">
        <block wx:if="{{!showMeaning}}">
          <view class="reveal-button" bindtap="onShowMeaning">
            点击查看释义
          </view>
        </block>

        <block wx:else>
          <view class="meaning-card">
            <view class="info-block">
              <text class="info-label">中文释义</text>
              <text class="info-text">{{words[currentIndex].meaning}}</text>
            </view>

            <view class="info-block">
              <text class="info-label">记忆法</text>
              <text class="info-text">{{words[currentIndex].memory_tip}}</text>
            </view>

            <view class="info-block">
              <text class="info-label">例句</text>
              <text class="info-text">{{words[currentIndex].sentence}}</text>
            </view>
          </view>
        </block>
      </view>
    </view>

    <view class="action-row">
      <button class="action-button action-button--known" bindtap="onKnow">
        认识
      </button>
      <button class="action-button action-button--unknown" bindtap="onDontKnow">
        不认识
      </button>
    </view>
  </block>

  <view wx:else class="finish-panel">
    <text class="finish-emoji">🎉🏆</text>
    <text class="finish-title">今日学习报告</text>
    <text class="finish-summary">
      认识了 {{sessionRecognized}} 个单词，记错了 {{sessionUnrecognized}} 个单词
    </text>
    <text wx:if="{{finishRewardCoins}}" class="finish-reward">🎉 恭喜完成今日任务！获得 {{finishRewardCoins}} 枚金币奖励！</text>
    <button class="study-more-button" bindtap="onStudyMore">🔥 意犹未尽？再学 5 个！</button>
    <button class="finish-button" bindtap="onGoWords">
      查看我的词库
    </button>
  </view>
</view>
