.page,
.game-page {
  min-height: 100vh;
}

.game-page {
  padding: 36rpx 28rpx 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #dff7ff 0%, #eef8ff 45%, #fef6df 100%);
}

.game-panel {
  width: 100%;
  max-width: 680rpx;
  padding: 44rpx 28rpx;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 18rpx 40rpx rgba(95, 133, 180, 0.16);
  backdrop-filter: blur(8rpx);
}

.game-status {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  flex-wrap: wrap;
}

.heart-text,
.combo-text,
.score-text {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.heart-text {
  background: #ffe8ec;
  color: #e25b6a;
}

.combo-text {
  background: #fff1d9;
  color: #d58b00;
}

.score-text {
  background: #eef5ff;
  color: #5a8dee;
}

.meaning {
  display: block;
  margin-top: 24rpx;
  font-size: 44rpx;
  font-weight: 700;
  color: #2f3a33;
  text-align: center;
}

.answer-slots {
  margin-top: 32rpx;
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 14rpx;
}

.slot {
  width: 72rpx;
  height: 84rpx;
  border-bottom: 6rpx solid #9fc4ff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.slot-letter {
  font-size: 42rpx;
  font-weight: 700;
  color: #48607a;
}

.success-tip {
  margin-top: 22rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #4fa38a;
  text-align: center;
}

.letters-area {
  margin-top: 36rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 20rpx;
}

.letter-block {
  width: 96rpx;
  height: 96rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  font-weight: 700;
  color: #ffffff;
  background: linear-gradient(135deg, #6eb6ff 0%, #7b8cff 100%);
  box-shadow: 0 14rpx 24rpx rgba(90, 141, 238, 0.22);
  transition: transform 0.15s ease;
}

.letter-block:active {
  transform: scale(0.9);
}

.bottom-actions {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.primary-button,
.secondary-button {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border: none;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.primary-button::after,
.secondary-button::after {
  border: none;
}

.primary-button {
  background: #4fa38a;
  color: #ffffff;
}

.secondary-button {
  background: #eef3f6;
  color: #6c7b85;
}

.finish-panel {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.finish-emoji {
  font-size: 84rpx;
}

.finish-title {
  margin-top: 20rpx;
  font-size: 42rpx;
  font-weight: 700;
  color: #2f3a33;
  text-align: center;
}

.finish-text {
  margin-top: 18rpx;
  font-size: 30rpx;
  line-height: 1.8;
  color: #6d7f77;
  text-align: center;
}
