.pet-page {
  min-height: 100vh;
  padding: 32rpx 24rpx 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pet-card {
  width: 100%;
  max-width: 680rpx;
  padding: 40rpx 32rpx 48rpx;
  border-radius: 36rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f6fbf7 100%);
  box-shadow: 0 18rpx 40rpx rgba(117, 150, 131, 0.12);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.pet-level {
  font-size: 40rpx;
  font-weight: 700;
  color: #2f3a33;
}

.progress-track {
  width: 100%;
  height: 18rpx;
  margin-top: 16rpx;
  border-radius: 999rpx;
  background: #e7efe9;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #6bd7a7 0%, #4fa38a 100%);
  transition: width 0.35s ease;
}

.progress-text {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #7a8f85;
}

.pet-stage {
  position: relative;
  margin-top: 40rpx;
  height: 260rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pet-emoji {
  font-size: 160rpx;
  animation: petBreath 2s ease-in-out infinite;
}

.pet-emoji--active {
  animation: petFeed 0.5s ease;
}

.pet-heart {
  position: absolute;
  top: 10rpx;
  right: -10rpx;
  font-size: 52rpx;
  animation: popHeart 0.5s ease;
}

.coin-text {
  margin-top: 12rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #d58b00;
}

.feed-button {
  width: 100%;
  margin-top: 36rpx;
  height: 96rpx;
  line-height: 96rpx;
  border: none;
  border-radius: 24rpx;
  background: #4fa38a;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
}

.feed-button--earn {
  background: #f29a62;
}

.feed-button::after {
  border: none;
}

.game-link {
  margin-top: 22rpx;
  font-size: 28rpx;
  color: #5a8dee;
}

@keyframes petBreath {
  0% { transform: scale(1); }
  50% { transform: scale(1.06); }
  100% { transform: scale(1); }
}

@keyframes petFeed {
  0% { transform: scale(1); }
  50% { transform: scale(1.2); }
  100% { transform: scale(1); }
}

@keyframes popHeart {
  0% { transform: scale(0.7); opacity: 0; }
  60% { transform: scale(1.15); opacity: 1; }
  100% { transform: scale(1); opacity: 1; }
}
